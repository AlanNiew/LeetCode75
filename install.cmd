    return null;
  }

    // ---------------- Dim everything except the trigger branch (sibling branches only) ----------------
    function dimAllOtherBranches(container, trigger){
      undim(); // clear previous

      const dimEls = [];
      const wrappedTexts = [];
      const pathEls = [];

      // Build ELEMENT-only path [container -> ... -> trigger]
