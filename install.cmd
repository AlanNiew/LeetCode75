      cancelCloseTimer();
    }

    function forceClose(){
      if (!current) return;
      bubble.classList.remove("is-open");
      bubble.setAttribute("aria-hidden","true");
      current.setAttribute("aria-expanded","false");
      current = null;
      undim();
      hoverCount = 0;
      cancelCloseTimer();
